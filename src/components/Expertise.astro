<style>
  /*
   * Expertise — responsive card grid of skill areas.
   *
   * The grid uses a 1px gap with the grid container's background set to
   * the border color — this creates thin divider lines between cards
   * without needing explicit borders on each card.
   *
   * Three cards: one row of three on wide viewports; Build/CI/CD/release and
   * dev+agentic are each merged topics. Stacked on small screens.
   * Same scroll-reveal and hover patterns as Experience cards.
   */

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  /* Each card starts hidden for scroll-reveal (see Experience for details) */
  .expertise-card {
    padding: 45px;
    background: var(--color-bg-secondary);
    opacity: 0;
    transform: translateY(16px);
    transition:
      box-shadow 0.2s ease,
      background 0.2s ease,
      opacity 0.5s ease,
      transform 0.5s ease;
  }

  .expertise-card:hover {
    box-shadow: inset 3px 0 0 var(--color-accent);
    background: var(--color-bg-tertiary);
  }

  .expertise-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .expertise-icon {
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--color-prompt);
  }

  .expertise-icon svg {
    width: 28px;
    height: 28px;
  }

  .expertise-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .expertise-card p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.85;
  }

  @media (max-width: 1000px) {
    .expertise-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
